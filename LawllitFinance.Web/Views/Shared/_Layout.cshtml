@{
    var theme    = User.FindFirst("theme")?.Value    ?? "dark";
    var fontSize = User.FindFirst("font_size")?.Value ?? "normal";
    var bsTheme  = theme == "high-contrast" ? "dark" : theme;
    var pageTitle = ViewData["Title"] is string t && !string.IsNullOrEmpty(t)
        ? t + " · lawllitfinance"
        : "lawllitfinance · Controle financeiro pessoal";
    var pageDescription = ViewData["Description"] as string
        ?? "Controle suas receitas e despesas, acompanhe cotações em tempo real e mantenha suas finanças organizadas.";
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
}
<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="@bsTheme" data-theme="@theme" @(fontSize != "normal" ? $"data-font-size=\"{fontSize}\"" : "")>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@pageTitle</title>
    <meta name="description" content="@pageDescription">
    <meta name="robots" content="@(User.Identity?.IsAuthenticated == true ? "noindex,nofollow" : "index,follow")">
    <link rel="canonical" href="@canonicalUrl">

    <meta property="og:type" content="website">
    <meta property="og:title" content="@pageTitle">
    <meta property="og:description" content="@pageDescription">
    <meta property="og:url" content="@canonicalUrl">
    <meta property="og:locale" content="pt_BR">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/app.css" rel="stylesheet">
    <link rel="icon" type="image/svg+xml"
          href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%230a0a0a'/><text x='16' y='23' text-anchor='middle' font-family='monospace' font-weight='700' font-size='20' fill='%234ade80'>L</text></svg>">
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-expand-lg sticky-top border-bottom" id="main-nav">
            <div class="container-lg">
                <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                    lawllit<span class="brand-finance">finance</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navContent">
                    <ul class="navbar-nav me-auto gap-1">
                        <li class="nav-item">
                            <a id="nav-dashboard" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                               asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a id="nav-transactions" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")"
                               asp-controller="Transaction" asp-action="Index">Transações</a>
                        </li>
                        <li class="nav-item">
                            <a id="nav-categories" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                               asp-controller="Category" asp-action="Index">Categorias</a>
                        </li>
                        <li class="nav-item">
                            <a id="nav-quotes" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Quotes" ? "active" : "")"
                               asp-controller="Quotes" asp-action="Index">Cotações</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">
                        <a id="nav-profile" asp-controller="Profile" asp-action="Index" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-2">
                            <span class="nav-avatar-btn">@(User.Identity?.Name?.Substring(0, 1).ToUpper())</span>
                            @User.Identity?.Name
                        </a>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-box-arrow-right"></i> Sair
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </nav>

    }
    else
    {
        <nav class="navbar sticky-top border-bottom">
            <div class="container-lg d-flex align-items-center justify-content-between">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    lawllit<span class="brand-finance">finance</span>
                </a>
                <div class="d-flex gap-2">
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-sm btn-outline-secondary">Entrar</a>
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-sm btn-primary">Cadastrar</a>
                </div>
            </div>
        </nav>
    }

    <partial name="_Notification" />

    @RenderBody()

    <footer>
        <span>© @DateTime.Now.Year · Desenvolvido por <span class="text-body">Lucas</span> <span class="text-green">Paineli</span></span>
        <a href="https://github.com/paiineli" target="_blank" rel="noopener" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
        </a>
        <a href="https://www.linkedin.com/in/lucaspaineli/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
            </svg>
        </a>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
